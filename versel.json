{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/analisar", "dest": "/api/analisar.js", "methods": ["POST", "OPTIONS"] },
    { "src": "/api/placa", "dest": "/api/placa.js", "methods": ["GET", "OPTIONS"] },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
